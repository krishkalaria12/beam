{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "rootDirs": ["."],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src",
    "src/main.tsx",
    "src/routeTree.gen.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "flare-main",
    "sidecar",
    "packages",
    "dist",
    "node_modules"
  ]
}
