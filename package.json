{
  "name": "beam",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "sidecar"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "serve": "vite preview",
    "start": "vite",
    "check-types": "tsc --noEmit",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check",
    "sidecar:build": "bun run --cwd sidecar build",
    "sidecar:check": "bun run --cwd sidecar check",
    "compat:test": "bun scripts/test-extension-compatibility.mjs",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build"
  },
  "dependencies": {
    "@base-ui/react": "^1.0.0",
    "@cloudflare/speedtest": "^1.7.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@flare/protocol": "workspace:*",
    "@hookform/resolvers": "^5.1.1",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.0.3",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/vite": "^4.0.15",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.141.1",
    "@tanstack/react-virtual": "^3.13.19",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.2",
    "ai": "^6.0.105",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "emojibase-data": "^17.0.0",
    "file-type": "^21.3.0",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.4",
    "msgpackr": "^1.11.4",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "2.15.4",
    "shadcn": "^3.6.2",
    "sonner": "^2.0.5",
    "streamdown": "^2.3.0",
    "tailwind-merge": "^3.3.1",
    "tauri-plugin-clipboard-api": "^2.1.11",
    "tw-animate-css": "^1.2.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
