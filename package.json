{
  "name": "beam",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://github.com/krishkalaria12/beam",
  "bugs": {
    "url": "https://github.com/krishkalaria12/beam/issues"
  },
  "license": "MIT",
  "author": "Krish Kalaria",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krishkalaria12/beam.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "oxlint .",
    "check": "oxlint && oxfmt --check .",
    "web:dev": "turbo -F web dev",
    "desktop:frontend:dev": "turbo -F desktop desktop:frontend:dev",
    "desktop:frontend:build": "turbo -F desktop desktop:frontend:build",
    "desktop:dev": "turbo -F desktop desktop:dev",
    "desktop:build": "turbo -F desktop desktop:build",
    "web:build": "turbo -F web build",
    "web:preview": "bun run --cwd apps/web preview",
    "tauri": "turbo -F desktop tauri",
    "extension-protocol:generate": "bun run --cwd packages/extension-protocol generate:ts",
    "extension-protocol:check": "bun run --cwd packages/extension-protocol check-types",
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "rust:fmt": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --all",
    "rust:fmt:check": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --all -- --check",
    "extension-manager:build": "bun run --cwd packages/extension-manager build",
    "extension-manager:check": "bun run --cwd packages/extension-manager check-types",
    "create:extension": "bun run --cwd packages/beam-api build && node packages/beam-api/bin/run.js create",
    "publish:beam-api": "bun infra/scripts/publish-beam-api.ts",
    "publish:beam-utils": "bun infra/scripts/publish-beam-utils.ts",
    "aur:update:beam-launcher-bin": "bun infra/scripts/update-aur-beam-launcher-bin.ts",
    "store:publish": "bun infra/scripts/publish-store-package.ts",
    "store:publish:all": "bun infra/scripts/publish-store-package.ts --all",
    "store:validate": "bun infra/scripts/validate-store-package.ts --all"
  },
  "devDependencies": {
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.2.19"
}
