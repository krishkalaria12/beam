  "devDependencies": {
    "@tanstack/react-router-devtools": "^1.141.1",
    "@tanstack/router-plugin": "^1.141.1",
    "@tauri-apps/cli": "^2.4.0",
    "@types/node": "^22.13.14",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "postcss": "^8.5.3",
