---
---

<section id="features" class="shell py-16">
  <div class="mb-8 text-center">
    <p class="mb-4 text-[0.85rem] font-bold uppercase tracking-[0.04em] text-[#5f5f5f]">Features</p>
    <h2 class="max-w-[54rem] mx-auto text-[clamp(2rem,4vw,3.5rem)] leading-[1.05] tracking-[-0.05em] font-bold">Built for the launcher workflows Linux users actually want</h2>
  </div>

  <div class="grid grid-cols-3 gap-6">
    <article class="col-span-2 rounded-[1.75rem] border-[3px] border-black bg-[#dff4ff] p-10 [box-shadow:8px_8px_0_0_#000] flex flex-col overflow-hidden relative transition-transform duration-[160ms] hover:translate-x-1 hover:translate-y-1 hover:[box-shadow:4px_4px_0_0_#000]">
      <div class="flex-1 flex items-start mb-8 min-h-[120px]">
        <img class="w-full h-[220px] object-cover object-top rounded-[0.85rem] border-[3px] border-black [box-shadow:4px_4px_0_0_#000]" src="/calculator.png" alt="Calculator" />
      </div>
      <div class="mt-auto">
        <h3 class="mb-[0.85rem] text-[1.8rem] leading-[1.2]">Built-in Calculator</h3>
        <p class="text-[#4f4f4f] leading-[1.6] font-medium text-[1.1rem] m-0">Perform quick math and unit conversions without ever leaving the launcher. Seamless and instantly accessible.</p>
      </div>
    </article>
    
    <article class="col-span-1 rounded-[1.75rem] border-[3px] border-black bg-[#fff5b3] p-10 [box-shadow:8px_8px_0_0_#000] flex flex-col overflow-hidden relative transition-transform duration-[160ms] hover:translate-x-1 hover:translate-y-1 hover:[box-shadow:4px_4px_0_0_#000]">
      <div class="flex-1">
        <h3 class="mb-[0.85rem] text-[1.8rem] leading-[1.2]">Clipboard History</h3>
        <p class="text-[#4f4f4f] leading-[1.6] font-medium text-[1.1rem] m-0">Never lose a copied link or text snippet again. Instantly access your clipboard history at a moment's notice.</p>
      </div>
      <div class="flex items-end mt-8 min-h-[120px]">
        <img class="w-full h-[220px] object-cover object-top rounded-[0.85rem] border-[3px] border-black [box-shadow:4px_4px_0_0_#000]" src="/clipboard.png" alt="Clipboard History" />
      </div>
    </article>
    
    <article class="col-span-1 rounded-[1.75rem] border-[3px] border-black bg-[#ffd8cc] p-10 [box-shadow:8px_8px_0_0_#000] flex flex-col overflow-hidden relative transition-transform duration-[160ms] hover:translate-x-1 hover:translate-y-1 hover:[box-shadow:4px_4px_0_0_#000]">
      <div class="flex-1">
        <h3 class="mb-[0.85rem] text-[1.8rem] leading-[1.2]">Custom Theming</h3>
        <p class="text-[#4f4f4f] leading-[1.6] font-medium text-[1.1rem] m-0">Playful themes, varied colors, and personalized aesthetics. Make your workflow entirely your own.</p>
      </div>
      <div class="flex items-end mt-8 min-h-[120px]">
        <img class="w-full h-[220px] object-cover object-top rounded-[0.85rem] border-[3px] border-black [box-shadow:4px_4px_0_0_#000]" src="/custom-theme.png" alt="Custom Theming" />
      </div>
    </article>

    <article class="col-span-2 rounded-[1.75rem] border-[3px] border-black bg-[#7ed2ff] p-10 [box-shadow:8px_8px_0_0_#000] flex flex-col overflow-hidden relative transition-transform duration-[160ms] hover:translate-x-1 hover:translate-y-1 hover:[box-shadow:4px_4px_0_0_#000]">
      <div class="flex-1">
        <h3 class="mb-[0.85rem] text-[1.8rem] leading-[1.2]">File Search</h3>
        <p class="text-[#4f4f4f] leading-[1.6] font-medium text-[1.1rem] m-0">Instantly search through your local files, documents, and folders. Find exactly what you need without breaking your flow.</p>
      </div>
      <div class="flex items-end mt-8 min-h-[120px]">
        <img class="w-full h-[220px] object-cover object-top rounded-[0.85rem] border-[3px] border-black [box-shadow:4px_4px_0_0_#000]" src="/file-search.png" alt="File Search" />
      </div>
    </article>
  </div>
</section>