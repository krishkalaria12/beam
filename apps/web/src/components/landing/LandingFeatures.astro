---
---

<section id="features" class="shell content-section">
  <div class="section-heading">
    <p>Features</p>
    <h2>Built for the launcher workflows Linux users actually want</h2>
  </div>

  <div class="bento-grid">
    <!-- Top Left: Wide (Span 2) -->
    <article class="bento-card bento-span-2 sky">
      <div class="bento-visual top">
        <img class="bento-image" src="/calculator.png" alt="Calculator" />
      </div>
      <div class="bento-content align-bottom">
        <h3>Built-in Calculator</h3>
        <p>Perform quick math and unit conversions without ever leaving the launcher. Seamless and instantly accessible.</p>
      </div>
    </article>
    
    <!-- Top Right: Narrow (Span 1) -->
    <article class="bento-card bento-span-1 yellow">
      <div class="bento-content">
        <h3>Clipboard History</h3>
        <p>Never lose a copied link or text snippet again. Instantly access your clipboard history at a moment's notice.</p>
      </div>
      <div class="bento-visual bottom">
        <img class="bento-image" src="/clipboard.png" alt="Clipboard History" />
      </div>
    </article>
    
    <!-- Bottom Left: Narrow (Span 1) -->
    <article class="bento-card bento-span-1 coral">
      <div class="bento-content">
        <h3>Custom Theming</h3>
        <p>Playful themes, varied colors, and personalized aesthetics. Make your workflow entirely your own.</p>
      </div>
      <div class="bento-visual bottom">
        <img class="bento-image" src="/custom-theme.png" alt="Custom Theming" />
      </div>
    </article>

    <!-- Bottom Right: Wide (Span 2) -->
    <article class="bento-card bento-span-2 sky-dark">
      <div class="bento-content">
        <h3>File Search</h3>
        <p>Instantly search through your local files, documents, and folders. Find exactly what you need without breaking your flow.</p>
      </div>
      <div class="bento-visual bottom">
        <img class="bento-image" src="/file-search.png" alt="File Search" />
      </div>
    </article>
  </div>
</section>
