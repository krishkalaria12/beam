---

<section id="extensions" class="shell py-16">
  <div class="mb-8 text-center">
    <p class="mb-4 text-[0.85rem] font-bold uppercase tracking-[0.04em] text-[#5f5f5f]">Extensions</p>
    <h2 class="max-w-[54rem] mx-auto text-[clamp(2rem,4vw,3.5rem)] leading-[1.05] tracking-[-0.05em] font-bold">Thousands of integrations. One launcher.</h2>
  </div>

  <div class="grid grid-cols-[1fr_1.2fr] gap-12 items-center mt-8 rounded-[2rem] border-4 border-black bg-white p-12 [box-shadow:12px_12px_0_0_#000]">
    <div class="flex flex-col gap-8 min-w-0">
      <p class="text-[1.15rem] leading-[1.6] text-[#4b4b4b] font-medium m-0">
        Create custom extensions securely or bring in <strong class="text-black font-bold">Raycast-compatible</strong> extensions directly into Beam. Supercharge your workflow with community plugins or your own custom scripts.
      </p>

      <div class="relative w-full overflow-hidden py-6">
        <div class="absolute top-0 left-0 w-[30px] h-full z-[2] pointer-events-none bg-gradient-to-r from-white to-transparent"></div>
        <div class="absolute top-0 right-0 w-[30px] h-full z-[2] pointer-events-none bg-gradient-to-l from-white to-transparent"></div>
        <div class="flex w-max">
          <div class="flex items-center gap-12 pl-12 animate-marquee">
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/github" alt="GitHub" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/spotify" alt="Spotify" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/discord" alt="Discord" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/figma" alt="Figma" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/notion" alt="Notion" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/linear" alt="Linear" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/slack" alt="Slack" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/googlechrome" alt="Chrome" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/github" alt="GitHub" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/spotify" alt="Spotify" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/discord" alt="Discord" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/figma" alt="Figma" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/notion" alt="Notion" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/linear" alt="Linear" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/slack" alt="Slack" />
            <img class="h-8 w-auto opacity-60 transition-all duration-200 hover:opacity-100 hover:scale-115 cursor-pointer grayscale hover:grayscale-0" src="https://cdn.simpleicons.org/googlechrome" alt="Chrome" />
          </div>
        </div>
      </div>
    </div>

    <div class="relative">
      <img class="w-full h-auto rounded-[1rem] border-[3px] border-black [box-shadow:8px_8px_0_0_#000] block" src="/raycast-extension.png" alt="Beam Extension Store" />
    </div>
  </div>
</section>