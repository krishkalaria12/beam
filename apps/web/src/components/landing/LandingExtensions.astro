<section id="extensions" class="shell content-section extensions-section">
  <div class="section-heading">
    <p>Extensions</p>
    <h2>Thousands of integrations. One launcher.</h2>
  </div>

  <div class="extensions-layout">
    <div class="extensions-info">
      <p class="extensions-desc">
        Create custom extensions securely or bring in <strong>Raycast-compatible</strong> extensions directly into Beam. Supercharge your workflow with community plugins or your own custom scripts.
      </p>

      <div class="marquee-wrapper">
        <div class="marquee">
          <div class="marquee-content">
            <!-- First set of icons -->
            <img src="https://cdn.simpleicons.org/github" alt="GitHub" />
            <img src="https://cdn.simpleicons.org/spotify" alt="Spotify" />
            <img src="https://cdn.simpleicons.org/discord" alt="Discord" />
            <img src="https://cdn.simpleicons.org/figma" alt="Figma" />
            <img src="https://cdn.simpleicons.org/notion" alt="Notion" />
            <img src="https://cdn.simpleicons.org/linear" alt="Linear" />
            <img src="https://cdn.simpleicons.org/slack" alt="Slack" />
            <img src="https://cdn.simpleicons.org/googlechrome" alt="Chrome" />
            <!-- Duplicate for infinite scroll -->
            <img src="https://cdn.simpleicons.org/github" alt="GitHub" />
            <img src="https://cdn.simpleicons.org/spotify" alt="Spotify" />
            <img src="https://cdn.simpleicons.org/discord" alt="Discord" />
            <img src="https://cdn.simpleicons.org/figma" alt="Figma" />
            <img src="https://cdn.simpleicons.org/notion" alt="Notion" />
            <img src="https://cdn.simpleicons.org/linear" alt="Linear" />
            <img src="https://cdn.simpleicons.org/slack" alt="Slack" />
            <img src="https://cdn.simpleicons.org/googlechrome" alt="Chrome" />
          </div>
        </div>
      </div>
    </div>

    <div class="extensions-visual">
      <img class="extensions-store-img" src="/raycast-extension.png" alt="Beam Extension Store" />
    </div>
  </div>
</section>
