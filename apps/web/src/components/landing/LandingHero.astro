<section class="hero shell">
  <div class="sticker">Linux launcher for fast workflows</div>

  <h1>
    Search your system.
    <br />
    <span>Keep the speed.</span>
  </h1>

  <p class="hero-copy">
    Beam is a lightweight command layer for Linux that brings apps, files,
    actions, and AI tools into one fast, playful surface
  </p>

  <div class="hero-actions">
    <button class="solid-button" type="button" disabled>Install</button>
    <a
      class="outline-button"
      href="https://github.com/krishkalaria12/beam"
      target="_blank">View repository</a
    >
  </div>

  <div class="product-frame">
    <div class="frame-topbar">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="frame-content">
      <aside class="sidebar-card">
        <p class="sidebar-label">Workspace</p>
        <h2>One launcher for everything.</h2>
        <ul>
          <li>Apps and files</li>
          <li>Clipboard and quick actions</li>
          <li>Commands and AI tools</li>
        </ul>
      </aside>

      <div class="launcher-card">
        <div class="launcher-search">
          <span class="launcher-icon">⌘</span>
