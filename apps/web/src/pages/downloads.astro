---
import Layout from '../layouts/Layout.astro';
import LandingHeader from '../components/landing/LandingHeader.astro';
import LandingFooter from '../components/landing/LandingFooter.astro';
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/700.css';
---

<Layout
  title="Download Beam | A playful command layer for Linux"
  description="Download Beam - a blazing-fast, Linux-first command launcher for apps, files, system actions, and extensions."
>
  <main class="beam-downloads">
    <div class="beam-orb beam-orb-coral"></div>
    <div class="beam-orb beam-orb-sky"></div>
    <div class="beam-orb beam-orb-sun"></div>

    <LandingHeader />

    <section class="shell flex flex-col items-center text-center py-20">

      <h1 class="mb-6 text-[clamp(3rem,8vw,5rem)] leading-[1.02] tracking-[-0.06em] font-bold">
        Download Beam
      </h1>

      <p class="max-w-[48rem] mb-16 text-[clamp(1.1rem,2vw,1.45rem)] leading-[1.7] text-[#616161] font-medium">
        Choose your preferred package format to get started
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-[56rem]">
        <a href="https://github.com/krishkalaria12/beam/releases/download/v1.0.7/beam_1.0.0_amd64.AppImage" target="_blank" class="flex flex-col items-center p-8 rounded-[1.5rem] border-4 border-black bg-white [box-shadow:8px_8px_0_0_#000] transition-transform hover:-translate-y-2 hover:[box-shadow:12px_12px_0_0_#000] no-underline">
          <div class="w-16 h-16 mb-4 flex items-center justify-center rounded-[1rem] border-2 border-black bg-[#7ed2ff] [box-shadow:3px_3px_0_0_#000]">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">AppImage</h3>
          <p class="text-sm text-[#616161]">Run on any Linux distro</p>
        </a>

        <a href="https://github.com/krishkalaria12/beam/releases/download/v1.0.7/beam_1.0.0_amd64.deb" target="_blank" class="flex flex-col items-center p-8 rounded-[1.5rem] border-4 border-black bg-white [box-shadow:8px_8px_0_0_#000] transition-transform hover:-translate-y-2 hover:[box-shadow:12px_12px_0_0_#000] no-underline">
          <div class="w-16 h-16 mb-4 flex items-center justify-center rounded-[1rem] border-2 border-black bg-[#ff9f7a] [box-shadow:3px_3px_0_0_#000]">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Debian / Ubuntu</h3>
          <p class="text-sm text-[#616161]">For Debian-based systems</p>
        </a>

        <a href="https://github.com/krishkalaria12/beam/releases/download/v1.0.7/beam-1.0.0-1.x86_64.rpm" target="_blank" class="flex flex-col items-center p-8 rounded-[1.5rem] border-4 border-black bg-white [box-shadow:8px_8px_0_0_#000] transition-transform hover:-translate-y-2 hover:[box-shadow:12px_12px_0_0_#000] no-underline">
          <div class="w-16 h-16 mb-4 flex items-center justify-center rounded-[1rem] border-2 border-black bg-[#a8d7a8] [box-shadow:3px_3px_0_0_#000]">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">RPM</h3>
          <p class="text-sm text-[#616161]">For Red Hat / Fedora</p>
        </a>
      </div>

      <div class="mt-16 p-6 rounded-[1.5rem] border-4 border-black bg-white [box-shadow:8px_8px_0_0_#000] max-w-[56rem] w-full">
        <h3 class="text-lg font-bold mb-4">Installation Instructions</h3>
        <div class="text-left text-[#616161] font-mono text-sm space-y-3">
          <p><span class="text-black font-bold">AppImage:</span> <code>chmod +x beam_1.0.0_amd64.AppImage && ./beam_1.0.0_amd64.AppImage</code></p>
          <p><span class="text-black font-bold">Debian/Ubuntu:</span> <code>sudo dpkg -i beam_1.0.0_amd64.deb</code></p>
          <p><span class="text-black font-bold">RPM:</span> <code>sudo rpm -i beam-1.0.0-1.x86_64.rpm</code></p>
        </div>
      </div>

      <div class="mt-8 p-6 rounded-[1.5rem] border-4 border-black bg-white [box-shadow:8px_8px_0_0_#000] max-w-[56rem] w-full">
        <h3 class="text-lg font-bold mb-4">Keyboard Binding</h3>
        <p class="text-[#616161] mb-4">Add the following to your compositor configuration to launch Beam with a global shortcut:</p>
        <div class="text-left text-[#616161] font-mono text-sm bg-[#f5f5f5] p-4 rounded-[0.5rem] overflow-x-auto">
          <pre class="m-0 whitespace-pre-wrap"># Hyprland
bind = SUPER, SPACE, exec, beam

# Sway
bindsym $mod+Space exec beam

# River
map -snap Lauch beam

# KDE Plasma (Shortcuts)
# Settings > Shortcuts > Custom > Add "beam"

# GNOME (Custom Shortcut)
# Settings > Keyboard > Custom Shortcuts > Add "beam"</pre>
        </div>
      </div>

      <div class="mt-8">
        <a href="https://github.com/krishkalaria12/beam/releases/latest" target="_blank" class="inline-flex items-center justify-center rounded-[1.2rem] border-2 border-black bg-white px-[1.65rem] py-4 text-base font-bold text-black no-underline [box-shadow:6px_6px_0_0_#000] transition-transform hover:translate-x-1 hover:translate-y-1 hover:[box-shadow:2px_2px_0_0_#000]">View on GitHub</a>
      </div>
    </section>

    <LandingFooter />
  </main>
</Layout>

<style is:global>
  .beam-downloads {
    position: relative;
    min-height: 100vh;
    background: linear-gradient(135deg, #fff9e6 0%, #fff 50%, #e6f7ff 100%);
  }
</style>