{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "beam",
  "version": "1.0.0",
  "identifier": "io.beam.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3001",
    "removeUnusedCommands": true,
    "beforeDevCommand": "bun run desktop:prepare && bun run desktop:frontend:dev",
    "beforeBuildCommand": "bun run desktop:prepare && bun run desktop:frontend:build"
  },
  "app": {
    "windows": [
      {
        "title": "beam",
        "width": 960,
        "height": 520,
        "center": true,
        "visible": false,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$HOME/.local/share/icons/**",
            "$HOME/.icons/**",
            "$HOME/.local/**/icons/**",
            "$HOME/.local/share/**/plugins/**",
            "$HOME/.local/share/plugins/**",
            "/usr/share/icons/**",
            "/usr/local/share/icons/**",
            "/usr/share/pixmaps/**",
            "/var/lib/flatpak/exports/share/icons/**",
            "/var/lib/snapd/desktop/icons/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/beam-data-control-server"],
    "resources": [
      "binaries/extension-manager.cjs",
      "../../../infra/desktop-integrations/gnome-shell/beam@beam-linux",
      "../../../infra/desktop-integrations/udev/70-beam-snippets.rules"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["beam", "raycast"]
      }
    }
  }
}
