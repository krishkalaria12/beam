{
  "manifest_version": 2,
  "name": "Beam Browser Bridge (Firefox)",
  "description": "Sync browser tabs/content with Beam launcher",
  "version": "1.0.0",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "http://*/*",
    "https://*/*",
    "file:///*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Beam Bridge"
  },
  "web_accessible_resources": ["block.html", "block.js"],
  "applications": {
    "gecko": {
      "id": "beam-bridge@beam.launcher"
    }
  }
}
