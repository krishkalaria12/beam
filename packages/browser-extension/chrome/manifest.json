{
  "manifest_version": 3,
  "name": "Beam Browser Bridge",
  "description": "Sync browser tabs/content with Beam launcher",
  "version": "1.0.0",
  "permissions": ["tabs", "scripting", "alarms", "storage"],
  "host_permissions": ["http://*/*", "https://*/*", "file:///*", "http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Beam Bridge"
  },
  "web_accessible_resources": [
    {
      "resources": ["block.html", "block.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
