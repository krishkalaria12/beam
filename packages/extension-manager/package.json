{
  "name": "@beam/extension-manager",
  "version": "1.0.0",
  "description": "Beam's extension runtime and packaging bridge",
  "keywords": [],
  "license": "MIT",
  "author": "Krish Kalaria",
  "main": "index.ts",
  "scripts": {
    "sync:beam-utils-vendor": "node scripts/sync-beam-utils-vendor.mjs",
    "build": "bun run --cwd ../beam-utils build && bun run sync:beam-utils-vendor && tsdown --config-loader unrun --config tsdown.config.ts && node scripts/verify-standalone-bundle.mjs && bun run sync:desktop-runtime",
    "sync:desktop-runtime": "mkdir -p ../../apps/desktop/src-tauri/binaries && cp dist/index.cjs ../../apps/desktop/src-tauri/binaries/extension-manager.cjs",
    "check": "tsc --noEmit",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@beam/extension-protocol": "workspace:*",
    "dequal": "^2.0.3",
    "pako": "^2.1.0",
    "react": "19.2.3",
    "react-reconciler": "^0.32.0"
  },
  "devDependencies": {
    "@beam/config": "workspace:*",
    "@types/node": "^24.0.0",
    "@types/pako": "^2.0.3",
    "@types/react": "19.2.7",
    "@types/react-reconciler": "^0.32.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.8.3"
  }
}
