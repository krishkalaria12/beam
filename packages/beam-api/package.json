{
  "name": "@beam-launcher/api",
  "version": "1.0.0",
  "description": "TypeScript SDK to build Beam extensions",
  "type": "commonjs",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/krishkalaria12/beam.git"
  },
  "bin": {
    "beam-api": "bin/run.js"
  },
  "files": [
    "dist",
    "bin",
    "templates",
    "types",
    "README.md"
  ],
  "main": "dist/src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/src/index.js",
      "require": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rm -rf dist && bunx tsc --outDir dist",
    "check-types": "bunx tsc --noEmit",
    "pack": "bun run build && bun pm pack",
    "docgen": "typedoc"
  },
  "dependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.3",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@types/node": ">=18",
    "@types/react": "19.2.7",
    "chokidar": "^4.0.3",
    "esbuild": "^0.25.2",
    "react": "19.2.3",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@beam/config": "workspace:*",
    "@bufbuild/protobuf": "^2.7.0",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "chai": "^4",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "ts-proto": "^2.7.5",
    "typedoc": "^0.28.13",
    "typedoc-github-theme": "^0.3.1",
    "typedoc-plugin-markdown": "^4.8.1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@types/node": ">=18",
    "@types/react": "19.2.7"
  },
  "oclif": {
    "bin": "beam-api",
    "commands": "./dist/src/commands",
    "dirname": "beam-api",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  }
}
