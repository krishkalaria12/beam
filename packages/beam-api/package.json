{
  "name": "@beam/api",
  "version": "1.0.0",
  "description": "TypeScript SDK to build Beam extensions",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "rm -rf dist && bunx tsc --outDir dist",
    "pack": "bun run build && bun pm pack",
    "docgen": "typedoc"
  },
  "bin": {
    "beam-api": "./bin/run.js"
  },
  "files": [
    "dist",
    "src",
    "bin"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/src/index.js",
  "dependencies": {
    "@jgoz/esbuild-plugin-typecheck": "^4.0.3",
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "@types/node": ">=18",
    "@types/react": "19.0.10",
    "chokidar": "^4.0.3",
    "esbuild": "^0.25.2",
    "react": "19.0.0",
    "zod": "^4.0.17"
  },
  "peerDependencies": {
    "@types/node": ">=18",
    "@types/react": "19.0.10"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.7.0",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "chai": "^4",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "ts-proto": "^2.7.5",
    "typedoc": "^0.28.13",
    "typedoc-github-theme": "^0.3.1",
    "typedoc-plugin-markdown": "^4.8.1",
    "typescript": "^5"
  },
  "oclif": {
    "bin": "beam-api",
    "dirname": "beam-api",
    "commands": "./dist/src/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " ",
    "topics": {}
  },
  "repository": "krishkalaria12/beam"
}
