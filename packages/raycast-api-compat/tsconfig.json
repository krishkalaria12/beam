{
  "extends": "@beam/config/tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@beam-launcher/api": ["../beam-api/types/index.d.ts"]
    }
  },
  "include": ["src"]
}
