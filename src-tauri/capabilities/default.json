{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-confirm",
    "dialog:allow-open",
    "clipboard:monitor-all",
    "clipboard:write-all",
    "shell:allow-open"
  ]
}
